# === Matthew's shell additions ===

# Convenience aliases
alias sv="source .venv/bin/activate"
alias ll='ls -alF'
alias la='ls -A'
alias l='ls -CF'

# mkdir + cd in one step
mkcd() { mkdir -p "$1" && cd "$1"; }

# CUDA (adjust path if RunPod uses a different version)
export PATH=$PATH:/usr/local/cuda/bin

# Secrets — loaded from ~/.secrets.env if it exists
if [ -f ~/.secrets.env ]; then
    set -a
    source ~/.secrets.env
    set +a
fi
